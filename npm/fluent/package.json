{
  "name": "@aotrino/fluent",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A Fluent UI starter for AOTrino apps: system-themed provider and a Fluent window caption. A template choice, not a platform mandate.",
  "license": "MIT",
  "author": "Aelyo Softworks",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "@aotrino/client": "*",
    "@aotrino/react": "*",
    "@fluentui/react-components": "^9.74.3",
    "@fluentui/react-icons": "^2.0.333",
    "react": ">=18"
  },
  "devDependencies": {
    "@aotrino/client": "*",
    "@aotrino/react": "*",
    "@fluentui/react-components": "^9.74.3",
    "@fluentui/react-icons": "^2.0.333",
    "@types/react": "^19.2.14",
    "react": "^19.2.5",
    "typescript": "~6.0.3"
  }
}
